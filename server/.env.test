# Test Environment Configuration
# This file is used by the test suite ONLY.
# It points to a separate database so tests NEVER touch the development database.
#
# IMPORTANT: The database name MUST end in "_test" — the globalSetup.ts has a
# safety guard that refuses to run if DATABASE_URL doesn't contain "_test".

DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/interview_diaries_test?schema=public"

# Use short, predictable secrets for the test environment
JWT_ACCESS_SECRET="test_access_secret_minimum_16_chars_ok"
JWT_REFRESH_SECRET="test_refresh_secret_minimum_16_chars_ok"
NODE_ENV="test"
PORT=5001
CORS_ORIGIN="http://localhost:5173"
