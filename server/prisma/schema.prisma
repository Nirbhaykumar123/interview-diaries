// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum Course {
  BTECH
  MTECH
}

enum UserStatus {
  UNVERIFIED
  ACTIVE
  REJECTED
  SUSPENDED
}

enum InterviewType {
  INTERNSHIP
  PLACEMENT
}

enum InterviewOutcome {
  SELECTED
  REJECTED
  PENDING
}

enum InterviewDifficulty {
  EASY
  MEDIUM
  HARD
}

enum InterviewStatus {
  DRAFT
  PUBLISHED
}

enum RoundType {
  ONLINE_TEST
  TECHNICAL
  HR
  MANAGERIAL
  GROUP_DISCUSSION
  OTHER
}

model User {
  id                              String          @id @default(uuid()) @db.Uuid
  email                           String          @unique
  username                        String          @unique
  passwordHash                    String          @map("password_hash")
  fullName                        String          @map("full_name")
  college                         String          @default("NIT Calicut")
  course                          Course          @default(BTECH)
  branch                          String          @default("CSE")
  graduationYear                  Int             @default(2026) @map("graduation_year")
  status                          UserStatus      @default(UNVERIFIED)
  isVerifiedBadge                 Boolean         @default(false) @map("is_verified_badge")
  role                            UserRole        @default(USER)
  isActive                        Boolean         @default(true) @map("is_active")
  isEmailVerified                 Boolean         @default(false) @map("is_email_verified")
  emailVerificationToken          String?         @unique @map("email_verification_token")
  emailVerificationTokenExpiresAt DateTime?       @map("email_verification_token_expires_at")
  lastLoginAt                     DateTime?       @map("last_login_at")
  failedLoginAttempts Int             @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?       @map("locked_until")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  profile             Profile?
  refreshTokens       RefreshToken[]
  interviews          Interview[]
  comments            Comment[]
  helpfulVotes        HelpfulVote[]
  bookmarks           Bookmark[]
  createdCompanies    Company[]       @relation("CompanyCreator")
  reportsCreated      Report[]        @relation("UserReporter")
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent    Notification[]  @relation("NotificationSender")
  verificationsReviewed Verification[] @relation("VerificationReviewer")
  adminNotesCreated     AdminNote[]
  auditLogsCreated     AuditLog[]
  isSuspended           Boolean        @default(false) @map("is_suspended")
  suspensionReason      String?        @map("suspension_reason") @db.Text

  @@map("users")
}

model Profile {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio            String?
  avatarUrl      String?  @map("avatar_url")
  linkedinUrl    String?  @map("linkedin_url")
  githubUrl      String?  @map("github_url")
  portfolioUrl   String?  @map("portfolio_url")
  currentCompany String?  @map("current_company")
  currentRole    String?  @map("current_role")
  skills         String[] @default([])
  isPrivate      Boolean  @default(false) @map("is_private")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")

  @@map("refresh_tokens")
}

model Company {
  id             String      @id @default(uuid()) @db.Uuid
  name           String      @unique
  slug           String      @unique
  description    String?     @db.Text
  logoUrl        String?     @map("logo_url")
  website        String?
  industry       String?
  location       String?
  isHiring       Boolean     @default(false) @map("is_hiring")
  interviewCount Int         @default(0) @map("interview_count")
  createdById    String?     @map("created_by_id") @db.Uuid
  createdBy      User?       @relation("CompanyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  interviews     Interview[]

  @@map("companies")
}

model Interview {
  id                String              @id @default(uuid()) @db.Uuid
  authorId          String              @map("author_id") @db.Uuid
  author            User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  companyId         String              @map("company_id") @db.Uuid
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Placement Context Info
  role              String              // e.g. "Software Engineer"
  type              InterviewType       // PLACEMENT or INTERNSHIP
  degree            Course              // BTECH or MTECH
  branch            String              // e.g. "CSE"
  cgpa              Float               // CGPA of student during drive
  
  // Recruitment Season Meta
  academicYear      String              @map("academic_year") // e.g. "2025-2026"
  placementBatch    Int                 @map("placement_batch") // e.g. 2026
  campusDriveDate   DateTime?           @map("campus_drive_date") // Date company visited
  
  // Compensation Details (Numeric)
  ctc               Float?              // LPA (null for Internships)
  stipend           Int?                // INR/Month (null for FTE)
  
  // Selection Metadata
  outcome           InterviewOutcome    // SELECTED, REJECTED, PENDING
  difficulty        InterviewDifficulty
  oaPlatform        String?             @map("oa_platform") // e.g. "HackerRank", "Mettl"
  eligibility       String?             @map("eligibility") @db.Text // e.g. ECE/CSE, >=8.0
  
  // Content & Comments
  overallExperience String              @map("overall_experience") @db.Text
  tips              String?             @db.Text
  status            InterviewStatus     @default(DRAFT)
  isVerified        Boolean             @default(false) @map("is_verified")
  helpfulCount      Int                 @default(0) @map("helpful_count")
  commentCount      Int                 @default(0) @map("comment_count")
  viewCount         Int                 @default(0) @map("view_count")
  isDeleted         Boolean             @default(false) @map("is_deleted")
  publishedAt       DateTime?           @map("published_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  rounds            Round[]
  comments          Comment[]
  helpfulVotes      HelpfulVote[]
  bookmarks         Bookmark[]
  reports           Report[]
  notifications     Notification[]
  verification      Verification?
  isHidden          Boolean             @default(false) @map("is_hidden")

  @@map("interviews")
}

model Round {
  id              String              @id @default(uuid()) @db.Uuid
  interviewId     String              @map("interview_id") @db.Uuid
  interview       Interview           @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  roundNumber     Int                 @map("round_number")
  roundType       RoundType           @map("round_type")
  description     String
  questionsAsked  String[]            @map("questions_asked")
  durationMinutes Int?                @map("duration_minutes")
  difficulty      InterviewDifficulty?
  createdAt       DateTime            @default(now()) @map("created_at")

  @@unique([interviewId, roundNumber])
  @@map("rounds")
}

model Comment {
  id          String    @id @default(uuid()) @db.Uuid
  interviewId String    @map("interview_id") @db.Uuid
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  authorId    String    @map("author_id") @db.Uuid
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content     String
  isDeleted   Boolean   @default(false) @map("is_deleted")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Self-referential fields for replies
  parentId    String?   @map("parent_id") @db.Uuid
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")

  reports       Report[]
  notifications Notification[]

  @@index([interviewId, parentId])
  @@map("comments")
}

model HelpfulVote {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewId String    @map("interview_id") @db.Uuid
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([userId, interviewId])
  @@map("helpful_votes")
}

model Bookmark {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewId String    @map("interview_id") @db.Uuid
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([userId, interviewId])
  @@map("bookmarks")
}

enum ReportReason {
  SPAM
  ABUSIVE
  FALSE_INFORMATION
  DUPLICATE
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum NotificationType {
  COMMENT
  REPLY
  HELPFUL_VOTE
  REPORT_RESOLUTION
  SYSTEM
}

model Report {
  id          String       @id @default(uuid()) @db.Uuid
  reporterId  String       @map("reporter_id") @db.Uuid
  reporter    User         @relation("UserReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  
  // Target entities (exactly one of these should be set)
  interviewId String?      @map("interview_id") @db.Uuid
  interview   Interview?   @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  commentId   String?      @map("comment_id") @db.Uuid
  comment     Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)

  reason      ReportReason
  details     String?      @db.Text
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  adminNotes  AdminNote[]

  @@index([status])
  @@map("reports")
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  recipientId String           @map("recipient_id") @db.Uuid
  recipient   User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  
  senderId    String?          @map("sender_id") @db.Uuid
  sender      User?            @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  type        NotificationType
  isRead      Boolean          @default(false) @map("is_read")
  
  // Context links
  interviewId String?          @map("interview_id") @db.Uuid
  interview   Interview?       @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  commentId   String?          @map("comment_id") @db.Uuid
  comment     Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([recipientId, isRead])
  @@map("notifications")
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

model Verification {
  id              String             @id @default(uuid()) @db.Uuid
  interviewId     String             @unique @map("interview_id") @db.Uuid
  interview       Interview          @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  status          VerificationStatus @default(PENDING)
  
  // Verification Evidence Links
  evidenceUrl     String?            @map("evidence_url") @db.Text
  evidenceType    String?            @map("evidence_type") // e.g. "OFFER_LETTER", "INTERVIEW_INVITATION"
  
  // Reviewer Context
  reviewerId      String?            @map("reviewer_id") @db.Uuid
  reviewer        User?              @relation("VerificationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  rejectionReason String?            @map("rejection_reason") @db.Text
  
  adminNotes      AdminNote[]
  
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([status])
  @@map("verifications")
}

model AdminNote {
  id             String        @id @default(uuid()) @db.Uuid
  authorId       String        @map("author_id") @db.Uuid
  author         User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  content        String        @db.Text
  
  // Context links
  reportId       String?       @map("report_id") @db.Uuid
  report         Report?       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  verificationId String?       @map("verification_id") @db.Uuid
  verification   Verification? @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  createdAt      DateTime      @default(now()) @map("created_at")

  @@map("admin_notes")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  actorId       String   @map("actor_id") @db.Uuid
  actor         User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  
  action        String   // e.g. "VERIFY_INTERVIEW", "REJECT_VERIFICATION", "HIDE_INTERVIEW", "RESTORE_INTERVIEW", "RESOLVE_REPORT"
  targetId      String   @map("target_id")
  targetType    String   @map("target_type") // e.g. "INTERVIEW", "COMMENT", "REPORT", "USER"
  
  reason        String?  @db.Text
  previousState String?  @map("previous_state") @db.Text // JSON snapshot
  newState      String?  @map("new_state") @db.Text      // JSON snapshot
  
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId])
  @@index([actorId])
  @@map("audit_logs")
}
