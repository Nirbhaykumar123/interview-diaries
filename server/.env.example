# ==========================================
# Application Configuration
# ==========================================
PORT=5000
NODE_ENV=development

# ==========================================
# Database Connection (Neon PostgreSQL)
# ==========================================
# Format: postgres://username:password@hostname:port/database?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/interview_diaries?schema=public"

# ==========================================
# Security & Session Authentication
# ==========================================
# Secure cryptographic secrets used to sign JWT tokens.
# Generation hint: Run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_ACCESS_SECRET="your_jwt_access_secret_minimum_32_characters_here_super_secret"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_minimum_32_characters_here_super_secret"

# ==========================================
# Cross-Origin Resource Sharing (CORS)
# ==========================================
CORS_ORIGIN="http://localhost:5173"
