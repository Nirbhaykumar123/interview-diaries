{
  "compilerOptions": {
    // Target and module target for modern backend node development
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],

    // Build directory output configuration
    "outDir": "./dist",
    "rootDir": "./src",

    // Strict typecheck rules
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    // Interoperability with CommonJS dependencies
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    // Developer experience helpers
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // Relative path mappings without deprecated baseUrl
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*",
    "prisma/seed.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/generated"
  ]
}
